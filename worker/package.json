{
  "name": "bbs-bargh-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply bbs-bargh-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply bbs-bargh-db --remote",
    "check:callbacks": "node scripts/check-telegram-callbacks.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "wrangler": "^4.0.0"
  }
}
